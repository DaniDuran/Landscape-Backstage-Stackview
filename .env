BACKSTAGE_CONTAINER_NAME=backstage
BACKSTAGE_PORT=7007
NODE_ENV=production

APP_TITLE=Stackview Backstage
ORG_NAME=My Company
APP_BASE_URL=http://localhost:7007
BACKEND_BASE_URL=http://localhost:7007
BACKEND_LISTEN=:7007
BACKEND_SECRET=local-backstage-secret
AUTH_SESSION_SECRET=replace-this-with-a-long-random-session-secret

POSTGRES_CONTAINER_NAME=backstage-postgres
POSTGRES_IMAGE_TAG=17
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=backstage
POSTGRES_PASSWORD=backstage
POSTGRES_DB=backstage

# Keycloak service
KEYCLOAK_CONTAINER_NAME=backstage-keycloak
KEYCLOAK_IMAGE_TAG=26.1
KEYCLOAK_PORT=8080
KEYCLOAK_HOSTNAME=http://localhost:8080
KEYCLOAK_HOSTNAME_BACKCHANNEL_DYNAMIC=true
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
KEYCLOAK_REALM=Thomas
KEYCLOAK_CLIENT_ID=MTI
KEYCLOAK_CLIENT_SECRET=stackview-client-secret
KEYCLOAK_REDIRECT_URI=http://localhost:7007/api/auth/oidc/handler/frame
KEYCLOAK_WEB_ORIGIN=http://localhost:7007

# Keycloak PostgreSQL service
KEYCLOAK_DB_CONTAINER_NAME=keycloak-postgres
KEYCLOAK_DB_IMAGE_TAG=17
KEYCLOAK_DB_PORT=5433
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak

# OIDC for Backstage
OIDC_CLIENT_ID=MTI
OIDC_CLIENT_SECRET=stackview-client-secret
OIDC_METADATA_URL=http://keycloak:8080/realms/Thomas/.well-known/openid-configuration
OIDC_CALLBACK_URL=http://localhost:7007/api/auth/oidc/handler/frame

GITHUB_TOKEN=ghp_local_dummy_token
